@model IEnumerable<KhoaNoiVuCNTT.Models.BoMon>

@{
    ViewData["Title"] = "Quản lý Bộ môn";
    var totalBoMon = Model.Count();
}

<style>
    body {
        background: #f9fafb;
    }

    .stat-card {
        border-radius: 12px;
        border: none;
        transition: 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

    .table-container {
        background: white;
        border-radius: 16px;
        overflow: hidden;
    }

    .modal-content {
        border-radius: 18px;
        border: none;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px;
    }
</style>

<div class="container-fluid py-4 px-lg-5">

    <!-- THỐNG KÊ -->
    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="card stat-card shadow-sm bg-primary text-white">
                <div class="card-body">
                    <p class="mb-1 small opacity-75">Tổng số Bộ môn</p>
                    <h3 class="fw-bold">@totalBoMon</h3>
                </div>
            </div>
        </div>

    </div>

    <!-- TOOLBAR -->
    <div class="card shadow-sm border-0 mb-4 px-3 py-3">

        <div class="row align-items-center g-3">

            <div class="col-lg-4">
                <input type="text" id="searchBoMon"
                       class="form-control"
                       placeholder="Tìm kiếm tên bộ môn...">
            </div>

            <div class="col-lg-8 text-lg-end">

                <button class="btn btn-outline-secondary me-2"
                        onclick="window.print()">
                    <i class="fas fa-print me-1"></i> In báo cáo
                </button>

                <button class="btn btn-success"
                        onclick="openCreateModal()">
                    <i class="fas fa-plus-circle me-1"></i> Thêm Bộ môn
                </button>

            </div>

        </div>

    </div>

    <!-- TABLE -->
    <div class="table-container shadow-sm border">

        <table class="table table-hover align-middle mb-0" id="boMonTable">

            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Mã Bộ môn</th>
                    <th>Tên Bộ môn</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td class="ps-4 fw-bold">
                            #@item.MaBoMon
                        </td>

                        <td>
                            <strong>@item.TenBoMon</strong>
                        </td>

                        <td class="text-center">

                            <div class="btn-group">

                                <button class="btn btn-sm btn-outline-warning"
                                        onclick="openEditModal('@item.MaBoMon','@Html.Raw(item.TenBoMon.Replace("'", "\\'"))')">
                                    <i class="fas fa-edit"></i>
                                </button>

                                <button class="btn btn-sm btn-outline-danger"
                                        onclick="confirmDelete('@item.MaBoMon','@Html.Raw(item.TenBoMon.Replace("'", "\\'"))')">
                                    <i class="fas fa-trash"></i>
                                </button>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>


        </table>

        <div class="p-3 bg-light">
            <span class="small text-muted">
                Hiển thị @Model.Count() bộ môn
            </span>
        </div>

    </div>

</div>

<!-- MODAL -->
<div class="modal fade" id="boMonModal" tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content shadow">

            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalTitle">Thêm Bộ môn</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form id="boMonForm" method="post">

                @Html.AntiForgeryToken()

                <input type="hidden" id="MaBoMon" name="MaBoMon">

                <div class="modal-body">

                    <label class="form-label">Tên Bộ môn</label>

                    <input type="text"
                           id="TenBoMon"
                           name="TenBoMon"
                           class="form-control"
                           required>

                </div>

                <div class="modal-footer border-0">

                    <button class="btn btn-light"
                            data-bs-dismiss="modal">
                        Đóng
                    </button>

                    <button type="submit"
                            class="btn btn-primary">
                        Lưu
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

        const modal = new bootstrap.Modal(document.getElementById('boMonModal'));
        const form = document.getElementById('boMonForm');


        // SEARCH
        document.getElementById('searchBoMon').addEventListener('keyup', function() {

        let value = this.value.toLowerCase();

        document.querySelectorAll('#boMonTable tbody tr')
        .forEach(row => {

        row.style.display =
        row.innerText.toLowerCase().includes(value)
        ? ''
        : 'none';

        });

        });


        // CREATE
        function openCreateModal() {

        document.getElementById("modalTitle").innerHTML =
        "<i class='fas fa-plus-circle text-success me-2'></i>Thêm Bộ môn";

        form.action = "/BoMon/Create";

        form.reset();

        modal.show();

        }


        // EDIT
        function openEditModal(id, name) {

        document.getElementById("modalTitle").innerHTML =
        "<i class='fas fa-edit text-warning me-2'></i>Chỉnh sửa Bộ môn";

        form.action = "/BoMon/Edit/" + id;

        document.getElementById("MaBoMon").value = id;

        document.getElementById("TenBoMon").value = name;

        modal.show();

        }


        // DELETE

        function confirmDelete(id, name) {

        Swal.fire({
        title: "Xác nhận xóa?",
        text: "Bạn có chắc muốn xóa bộ môn " + name + "?",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#d33",
        cancelButtonText: "Hủy",
        confirmButtonText: "Xóa"
        }).then((result) => {

        if (result.isConfirmed) {

        document.getElementById("deleteId").value = id;
        document.getElementById("deleteForm").submit();

        }

        });

        }


    </script>
    <form id="deleteForm" method="post" asp-controller="BoMon" asp-action="DeleteConfirmed">
        <input type="hidden" id="deleteId" name="id" />
    </form>

}