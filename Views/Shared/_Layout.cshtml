<!DOCTYPE html>
<html lang="vi">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Hệ thống nội bộ</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- ICON -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>

            body {
                background: #f4f6f9;
            }

            .sidebar {
                width: 240px;
                height: 100vh;
                position: fixed;
                background: #1e293b;
                color: white;
            }

                .sidebar .logo {
                    font-size: 20px;
                    font-weight: bold;
                    padding: 20px;
                    border-bottom: 1px solid rgba(255,255,255,.1);
                }

                .sidebar a {
                    display: block;
                    color: #cbd5e1;
                    padding: 14px 20px;
                    text-decoration: none;
                    transition: .2s;
                }

                    .sidebar a:hover {
                        background: #334155;
                        color: white;
                    }

                .sidebar i {
                    width: 22px;
                }

            .main {
                margin-left: 240px;
            }

            .topbar {
                background: white;
                padding: 12px 25px;
                border-bottom: 1px solid #eee;
            }

            .content {
                padding: 25px;
            }

            footer {
                background: white;
                border-top: 1px solid #eee;
            }

    </style>

</head>


<body>

    <!-- SIDEBAR -->

    <div class="sidebar">

        <div class="logo">
            🏫 Nội Vụ CNTT
        </div>

        <a asp-controller="Home" asp-action="Index">
            <i class="fa fa-home"></i> Trang chủ
        </a>

        <a asp-controller="CanBo" asp-action="Index">
            <i class="fa fa-user"></i> Cán bộ
        </a>

        <a asp-controller="BoMon" asp-action="Index">
            <i class="fa fa-building"></i> Bộ môn
        </a>

        <a asp-controller="VaiTro" asp-action="Index">
            <i class="fa fa-key"></i> Vai trò
        </a>

        <a asp-controller="ThongBao" asp-action="Index">
            <i class="fa fa-bell"></i> Thông báo
        </a>

        <a asp-controller="TaiLieu" asp-action="Index">
            <i class="fa fa-folder"></i> Tài liệu
        </a>

        <a asp-controller="LichCongTac" asp-action="Index">
            <i class="fa fa-calendar"></i> Lịch công tác
        </a>

    </div>


    <!-- MAIN -->

    <div class="main">

        <!-- TOPBAR -->

        <div class="topbar d-flex justify-content-between align-items-center">

            <h5 class="mb-0 fw-bold">
                @ViewData["Title"]
            </h5>

            <div>

                <span class="me-3 text-muted">
                    <i class="fa fa-user-circle"></i> Admin
                </span>

            </div>

        </div>


        <!-- CONTENT -->

        <div class="content">

            @RenderBody()

        </div>


        <!-- FOOTER -->

        <footer class="bg-dark text-white text-center mt-5 p-4">

            © 2026 - Hệ thống quản lý thông tin nội bộ

        </footer>

    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
