@model IEnumerable<KhoaNoiVuCNTT.Models.ThongBao>

@{
    ViewData["Title"] = "Quản lý Thông Báo";
    var total = Model.Count();
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            📢 Quản lý Thông Báo
        </h2>

        <button class="btn btn-success"
                onclick="openCreateModal()">
            ➕ Thêm thông báo
        </button>

    </div>


    <!-- CARD THỐNG KÊ -->
    <div class="row mb-4">

        <div class="col-md-3">

            <div class="card shadow border-0 bg-primary text-white">

                <div class="card-body">

                    <div class="small">Tổng thông báo</div>

                    <h3 class="fw-bold">@total</h3>

                </div>

            </div>

        </div>

    </div>


    <!-- SEARCH -->
    <div class="card shadow-sm mb-3">

        <div class="card-body">

            <input type="text"
                   id="searchInput"
                   class="form-control"
                   placeholder="🔍 Tìm thông báo...">

        </div>

    </div>


    <!-- TABLE -->
    <div class="card shadow">

        <div class="card-body p-0">

            <table class="table table-hover mb-0"
                   id="thongBaoTable">

                <thead class="table-dark">

                    <tr>
                        <th>Tiêu đề</th>
                        <th width="180">Ngày đăng</th>
                        <th width="160">Chức năng</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td class="fw-semibold">
                                @item.TieuDe
                            </td>

                            <td>
                                @item.NgayDang?.ToString("dd/MM/yyyy HH:mm")
                            </td>

                            <td>

                                <div class="btn-group">

                                    <a asp-action="Details"
                                           asp-route-id="@item.MaThongBao"
                                           class="btn btn-info btn-sm">
                                        Xem
                                    </a>

                                    <button class="btn btn-warning btn-sm"
                                            onclick="openEditModal('@item.MaThongBao','@Html.Raw(item.TieuDe.Replace("'", "\\'"))')">
                                        Sửa
                                    </button>

                                    <button class="btn btn-danger btn-sm"
                                            onclick="confirmDelete('@item.MaThongBao','@item.TieuDe')">
                                        Xóa
                                    </button>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>


<!-- MODAL -->
<div class="modal fade" id="thongBaoModal">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title"
                    id="modalTitle">
                    Thêm thông báo
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal"></button>

            </div>

            <form id="thongBaoForm"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       id="MaThongBao"
                       name="MaThongBao">

                <div class="modal-body">

                    <div class="mb-3">

                        <label>Tiêu đề</label>

                        <input type="text"
                               id="TieuDe"
                               name="TieuDe"
                               class="form-control"
                               required>

                    </div>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Đóng
                    </button>

                    <button type="submit"
                            class="btn btn-primary">
                        Lưu
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>


@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

        const modal =
        new bootstrap.Modal(document.getElementById('thongBaoModal'));

        const form =
        document.getElementById('thongBaoForm');


        // SEARCH
        document.getElementById('searchInput')
        .addEventListener('keyup', function() {

        let value =
        this.value.toLowerCase();

        document
        .querySelectorAll('#thongBaoTable tbody tr')
        .forEach(row => {

        row.style.display =
        row.innerText.toLowerCase()
        .includes(value)
        ? ''
        : 'none';

        });

        });


        // CREATE
        function openCreateModal() {

        document.getElementById("modalTitle").innerText =
        "Thêm thông báo";

        form.action =
        "/ThongBao/Create";

        form.reset();

        modal.show();

        }


        // EDIT
        function openEditModal(id, title) {

        document.getElementById("modalTitle").innerText =
        "Chỉnh sửa thông báo";

        form.action =
        "/ThongBao/Edit/" + id;

        document.getElementById("MaThongBao").value =
        id;

        document.getElementById("TieuDe").value =
        title;

        modal.show();

        }


        // DELETE
        function confirmDelete(id, name) {

        Swal.fire({
        title: "Xóa thông báo?",
        text: "Bạn có chắc muốn xóa " + name + "?",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#d33",
        confirmButtonText: "Xóa",
        cancelButtonText: "Hủy"
        }).then((result) => {

        if (result.isConfirmed) {

        window.location =
        "/ThongBao/DeleteConfirmed/" + id;

        }

        });

        }

    </script>

}
